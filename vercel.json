{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    { "src": "/assets/(.*)",   "dest": "/assets/$1" },
    { "src": "/uploads/(.*)",  "dest": "/uploads/$1" },
    { "src": "/favicon\\.ico", "dest": "/assets/img/st logo.png" },
    { "src": "/(.*)",          "dest": "/api/index.php" }
  ]
}
